#!/bin/bash
# This script must be 'sourced': . mfa  or  source mfa
echo "Cleanup & set new temporary credentials"
unset AWS_ACCESS_KEY_ID
unset AWS_SECRET_ACCESS_KEY
unset AWS_SESSION_TOKEN
echo

assumed_role=$(aws --profile default sts assume-role \
    --role-arn "arn:aws:iam::537835470382:role/users-poweruser-role" \
    --role-session-name "poweruser-session" \
    --duration-seconds 3600) \
    || { echo "ERROR: aws sts assume-role failed" >&2; return 1; }

echo "AWS response"
echo "$assumed_role"
echo

AWS_ACCESS_KEY_ID=$(echo "$assumed_role" | jq -r .Credentials.AccessKeyId)
AWS_SECRET_ACCESS_KEY=$(echo "$assumed_role" | jq -r .Credentials.SecretAccessKey)
AWS_SESSION_TOKEN=$(echo "$assumed_role" | jq -r .Credentials.SessionToken)

[[ -n "$AWS_ACCESS_KEY_ID" && "$AWS_ACCESS_KEY_ID" != "null" ]] \
    || { echo "ERROR: empty AccessKeyId — check assumed_role output above" >&2; return 1; }

export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
export AWS_DEFAULT_PROFILE="default"
