}

8etap() {
    chroot_script 8etap << 'EOF'
# Create guest user and configure groups
useradd -m -g users guest
echo 'exec startplasma-x11' > /home/guest/.xinitrc
chown -R guest:users /home/guest/
usermod -aG docker guest
usermod -aG wheel  guest
usermod -aG audio  guest
usermod -aG video  guest
echo "Wykonaj: passwd guest"
EOF
}

# ---------------------------------------------------------------------------
# FETCH / CONFIG
# ---------------------------------------------------------------------------

fetch() {
    echo "Przeladowuje stage3 $CD_STAGEFILE"
    cd "$CDLOC"
    [ ! -e "$CD_STAGEFILE" ] && wget -c "$CD_STAGETARBALL"
    umount_all
    [ ! -e "$CHROOT/home" ] && [ -n "$DEVCHROOT" ] && mount "$DEVCHROOT" "$CHROOT"
    [ ! -e "$CDLOC/$CD_STAGEFILE" ] && chroot_die "$CD_STAGEFILE nie znaleziony, najpierw wykonaj: v <profil> f"
    echo ">>> Rozpakowuje Gentoo stage3..."
    echo tar xJpf "$CDLOC/$CD_STAGEFILE" -C "$CHROOT"
    [ ! -e "$CHROOT/home" ] && tar xJpf "$CDLOC/$CD_STAGEFILE" -C "$CHROOT" || die "stage tarball extraction error"
    cp /etc/resolv.conf "${CHROOT}/etc"
    wget https://raw.githubusercontent.com/pwasiewi/gentools/master/usr/local/bin/gentoolcfg
    chmod 755 ./gentoolcfg
    ./gentoolcfg
    cp2konfig /config.txz "$CD_PROFILE"
}

config() {
    wget -c https://github.com/pwasiewi/gentools/archive/master.zip -O /master.zip
    cd /
    [ -e gentools-master ] && rm -rf gentools-master
    [ -e master.zip ] && unzip -qq master.zip \
        && cd gentools-master \
        && tar Jcf config.txz * \
        && mv config.txz / \
        && cd / \
        && rm -rf gentools-master master.zip
}

# ---------------------------------------------------------------------------
# KERNEL BUILD
# ---------------------------------------------------------------------------

build_kernel() {
    chroot_script genkernel-build << EOF
sed -i 's/CDROOT="0"/CDROOT="1"/g' /usr/share/genkernel/defaults/initrd.defaults
time MAKEOPTS="-j16 -l32" genkernel --makeopts=-j8 \
    --kernel-config=/usr/src/linux/.config --luks --lvm --no-clean all
sed -i 's/CDROOT="1"/CDROOT="0"/g' /usr/share/genkernel/defaults/initrd.defaults
EOF

    mv "${CHROOT}/boot/initr"*"-genkernel"* "${PROFILE}/initrd"
    [ ! -e "$PROFILE/tmp/kernel" ] && mkdir -p "$PROFILE/tmp/kernel"
    mv "${CHROOT}/boot/kernel-genkernel"* "${PROFILE}/tmp/kernel/bzImage"

    install_isolinux
}

# ---------------------------------------------------------------------------
# SQUASHFS: pre-compression chroot reorganisation + mksquashfs
# ---------------------------------------------------------------------------

chroot_moveandlink() {
    # Relocate volatile/large dirs to /usr so they survive across squashfs mounts.
    cp "${LIVECONF}/profiles/${CD_PROFILE}/.bash_history" "${CHROOT}/root" || die
    chroot_script moveandlink << 'EOF'
env-update
source /etc/profile
cd /var
[ ! -e /usr/cache ] && mkdir /usr/cache
[ -d cache/genkernel ] && mv cache/genkernel /usr/cache && ln -sfn ../../usr/cache/genkernel cache/genkernel
[ -d cache/edb ]       && mv cache/edb       /usr/cache && ln -sfn ../../usr/cache/edb       cache/edb
[ -d db ]              && mv db /usr          && ln -sfn ../usr/db db
cd /usr/share
[ -d X11 ] && mv X11 /var && ln -sfn ../../var/X11 X11
cd /etc
[ -d gconf ] && mv gconf /usr && ln -sfn ../usr/gconf gconf
cd /var/lib
[ -d texmf ] && mv texmf /usr && ln -sfn ../../usr/texmf texmf
chown -R hadoop:hadoop /hadoop/
chown -R guest:users   /home/guest/
EOF
}

squashfs_pack() {
    [ ! -e "$CHROOT/../iso" ] && mkdir "$CHROOT/../iso"
    echo "/usr/bin/mksquashfs ${CHROOT}/ ${CLOOP_FILE} -comp xz -noappend -always-use-fragments -mem 5G -b 1048576 -Xdict-size 100% -no-xattrs"
    #echo "/usr/bin/mksquashfs ${CHROOT}/ ${CLOOP_FILE} -comp zstd -Xcompression-level 22  -noappend -b 1048576 -no-xattrs -mem-percent 60"
    if [ "$RAMDISK" = "0" ]; then
        time /usr/bin/mksquashfs "${CHROOT}"/ "${CLOOP_FILE}" \
            -comp xz -noappend -always-use-fragments -mem 5G -b 1048576 -Xdict-size 100% -no-xattrs || chroot_die
	    #-comp zstd -Xcompression-level 22  -noappend -b 1048576 -no-xattrs -mem-percent 60 || chroot_die
    else
        time /usr/bin/mksquashfs "${CHROOT}"/ "${CLOOP_FILE}" \
            -comp xz -noappend -always-use-fragments -no-xattrs || chroot_die
	    #-comp zstd -Xcompression-level 22  -noappend -b 1048576 -no-xattrs -mem-percent 60 || chroot_die
    fi
}

# ---------------------------------------------------------------------------
# ISO / ISOLINUX LAYOUT  (legacy BIOS boot for USB pendrive)
# ---------------------------------------------------------------------------

install_isolinux() {
    # Populate ISO directory with syslinux/isolinux files for legacy BIOS boot.
    # extlinux.conf is used by syslinux on the USB; isolinux.cfg is for CD/ISO.
    install -d "${ISO}"           || die
    install -d "${ISO}/isolinux"  || die
    cp "${LIVECONF}/profiles/global/isolinux.bin"         "${ISO}/isolinux" || die
    cp "${LIVECONF}/profiles/global/isolinux.cfg"         "${ISO}/isolinux" || die
    cp "${LIVECONF}/profiles/global/extlinux.conf"        "${ISO}/isolinux" || die
    cp "${LIVECONF}/profiles/global/"*.lss                "${ISO}/isolinux" || die
    cp "${LIVECONF}/profiles/global/"*.msg                "${ISO}/isolinux" || die
    cp "${PROFILE}/initrd"                                "${ISO}/isolinux/initrd" || die
    cp "${PROFILETMP}/kernel/bzImage"                     "${ISO}/isolinux/gentoo" || die
    touch "${ISO}/livecd" || die
}

iso_create() {
    install_isolinux
}

cleanall() {
    rm -rf "$CHROOT/var/log/portage"/*
    rm -f  "$CHROOT/var/log"/*
    rm -rf "$CHROOT/var/cache/revdep-rebuild"/*
    rm -rf "$CHROOT/var/tmp/genkernel"/*
    rm -rf "$CHROOT/usr/share/doc/groff"*
    rm -rf "$CHROOT/usr/share/doc/freetds"*
    rm -rf "$CHROOT/usr/share/doc/docbook-xsl-stylesheets"*

    # Remove all locales except Polish and English
    find "$CHROOT/usr/share/locale" -mindepth 1 -maxdepth 1 -type d \
        ! -name 'en' ! -name 'en_US' ! -name 'en_GB' \
        ! -name 'pl' ! -name 'pl_PL' \
        -exec rm -rf {} +
}

make_isocd() {
    growisofs -Z /dev/sr0="${PROFILE}/livecd.iso"
}

chroot_e() {
    umount_all
    mount_all
    TERM=xterm chroot "$CHROOT" /bin/bash -l -c "cd /root && exec /bin/bash"
    umount_all
}

chroot_bis() {
    TERM=xterm chroot "$CHROOT" /bin/bash -l -c "cd /root && exec /bin/bash"
}

chroot_mc() {
    cd "${PROFILE}"
    [ -e /usr/bin/mc ] && mc || vim settings
}

profile_mc() {
    cd "${LIVECONF}/profiles/${CD_PROFILE}"
    [ -e /usr/bin/mc ] && mc || vim settings
}

binfmt() {
    binfmt-run
}

# ---------------------------------------------------------------------------
# ARM / CROSS-COMPILATION
# ---------------------------------------------------------------------------

cross() {
    echo "USE=\"static-libs\" crossdev -S --target armv7a-hardfloat-linux-gnueabi -oO /usr/portage"
    time USE="static-libs" crossdev -S --target armv7a-hardfloat-linux-gnueabi -oO /usr/portage
}

crossfirst() {
    crossdev -C armv7a-hardfloat-linux-gnueabi -f
    cross
    [ -e /usr/armv7a-hardfloat-linux-gnueabi.orig ] && rm -rf /usr/armv7a-hardfloat-linux-gnueabi.orig
    cp -a /usr/armv7a-hardfloat-linux-gnueabi /usr/armv7a-hardfloat-linux-gnueabi.orig
}

1arm() {
    umount_all
    cp /etc/resolv.conf "${CHROOT}/etc"
    gentoolcfg
    cp /config.txz "${CHROOT}"
    cd "${CHROOT}"
    tar Jxf config.txz
    sed -i 's/^\/dev\//\#\/dev\//g' etc/fstab
    quickpkg qemu --include-config y
    ROOT=${CHROOT} emerge --usepkgonly --oneshot --nodeps qemu
    gcc -static /usr/local/share/src/qemu-wrapper.c -Ofast -s -o "${CHROOT}/usr/local/bin/qemu-wrapper"
}

2arm() {
    chroot_script vcportdir << 'EOF'
eselect profile set 48  # arm/17.0/armv7a/desktop/plasma/systemd/merged-usr
emerge-webrsync
vcportarm
ln -sfn /usr/share/zoneinfo/Europe/Warsaw /etc/localtime
ln -sf /proc/self/mounts /etc/mtab
echo en_US.UTF-8 UTF-8 >> /etc/locale.gen
echo pl_PL.UTF-8 UTF-8 >> /etc/locale.gen
locale-gen
EOF
}

3arm() {
    chroot_script vcportdir << EOF
USE="-X -sound" e vim
e u eix
USE="-sdl" e u genlop net-misc/dhcpcd grub
e u gpm app-misc/mc ntpsec
e u app-eselect/eselect-repository
EOF
}

4arm() {
    chroot_script vcportdir << 'EOF'
e w
emerge @preserved-rebuild
EOF
}

5arm() {
    chroot_script vcportdir << EOF
cd /usr/src
[ ! -e linux-${KERNEL_ARM}.tar.gz ] && wget -O linux-${KERNEL_ARM}.tar.gz \
    https://github.com/raspberrypi/linux/archive/${KERNEL_ARM}.tar.gz
[ ! -d linux-${KERNEL_ARM} ] && tar xzf linux-${KERNEL_ARM}.tar.gz -C /usr/src
ln -sfn linux-${KERNEL_ARM} linux
cd linux
EOF
}

# ---------------------------------------------------------------------------
# COMMAND DISPATCH
# ---------------------------------------------------------------------------

case "$2" in
    f)      fetch           ;;
    k)      build_kernel    ;;
    a)
        cleanall
        chroot_moveandlink
        squashfs_pack
        iso_create
        ;;
    s)
        chroot_moveandlink
        squashfs_pack
        ;;
    i)      iso_create      ;;
    c)      make_isocd      ;;
    e)      chroot_e        ;;
    fmt)    binfmt          ;;
    r)      chroot_mc       ;;
    p)      profile_mc      ;;
    eb)     chroot_bis      ;;
    u)      umount_all      ;;
    cfg)    config          ;;
    cross1) cross           ;;
    cross0) crossfirst      ;;
    arm1)   1arm            ;;
    arm2)   2arm            ;;
    arm3)   3arm            ;;
    arm4)   4arm            ;;
    arm5)   5arm            ;;
    0)      0etap           ;;
    01)     1etap           ;;
    1)      0etap; 1etap    ;;
    2)      2etap           ;;
    3)      3etap           ;;
    4)      4etap           ;;
    5)      5etap           ;;
    6)      6etap           ;;
    7)      7etap           ;;
    8)      8etap           ;;
    0host)  HOST=1; 0etap   ;;
    1host)  HOST=1; 1etap   ;;
    2host)  HOST=1; 2etap   ;;
    3host)  HOST=1; 3etap   ;;
    4host)  HOST=1; 4etap   ;;
    5host)  HOST=1; 5etap   ;;
    6host)  HOST=1; 6etap   ;;
    7host)  HOST=1; 7etap   ;;
    8host)  HOST=1; 8etap   ;;
    *)      usage; exit 1   ;;
esac
exit 0
