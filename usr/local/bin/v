#!/bin/bash
# Piotr Wasiewicz 2005-2025
# Gentoo Linux LiveUSB/LiveCD generation and chroot management.
# Fragments taken from Gentoo official and unofficial scripts.
# Distributed under the GNU Public License version 2

# ---------------------------------------------------------------------------
# PROFILE DIRECTORY LAYOUT
# ---------------------------------------------------------------------------
# /etc/liveusb/
#   profiles/
#     global/                   -- shared across all profiles
#       settings                -- defines DIST, CCACHEDIR and other globals
#       isolinux.bin            -- legacy BIOS boot (isolinux/syslinux)
#       isolinux.cfg            -- legacy BIOS boot config
#       extlinux.conf           -- USB syslinux extlinux config
#       gentoo.lss              -- syslinux splash
#       boot.msg                -- syslinux boot message
#       help.msg                -- F2 help screen
#       help1.msg               -- F3 help screen (mount/grub instructions)
#     <profile>/                -- e.g. profiles/g/
#       settings                -- DEVCHROOT, CD_STAGEFILE, CD_STAGETARBALL,
#                                  RAMDISK (0=persistent chroot, 1=ramdisk),
#                                  BINHOST_MOUNT (1=bind-mount host binpkg caches,
#                                  only for profiles matching host arch/USE)
#       make.conf               -- deployed verbatim into chroot /etc/portage/
#       motd                    -- deployed into chroot /etc/motd
#       .bash_history           -- deployed into chroot /root/.bash_history
#       stage1-packages         -- (legacy, kept for reference) initial pkgs
#       stage2-packages         -- (legacy, kept for reference) extra pkgs
#
# RAMDISK=0  persistent chroot on $DEVCHROOT device, portage/distfiles bind-mounted
# RAMDISK=1  tmpfs-based liveusb, no persistent mounts
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
v: Gentoo Linux LiveUSB generation
Syntax: v <profile> <command> ...

Commands:
  e      enter chroot (mounts /dev, /proc, /sys etc. from host)
  eb     enter already-mounted chroot from second console (no mount)
  u      umount /dev, /proc, /sys etc. from chroot
  k      build kernel via genkernel for live USB
  s      compress system into livecd.squashfs
  a      run: cleanall + s (squashfs) + i (iso layout)
  i      populate ISO directory layout (isolinux files)
  c      burn ISO to DVD
  f      download and extract Gentoo stage3
  p      open profile config dir in mc
  r      open chroot dir in mc
  cfg    fetch gentools repository config
  0      run stage 0 only (portage dir setup + make.conf deploy)
  1      run stage 0 + 1 (locale, profile, base packages)
  2-8    run install stage N inside chroot
  0host  run stage 0 directly on host (no chroot)
  1host  run stage 1 directly on host
  2host-8host  run stage N directly on host
  cross0 remove and rebuild armv7a toolchain from scratch
  cross1 rebuild armv7a toolchain
  arm1-arm5  ARM cross-build stages
  fmt    configure qemu binfmt for cross-compilation
  -h|--help  show this help

Piotr Wasiewicz 2005-2025
Distributed under the GNU Public License version 2
EOF
}

die() {
    [ -n "$1" ] && echo "<${0}> ERROR: $1" || echo "<${0}> QUITTING."
    exit 1
}

# ---------------------------------------------------------------------------
# ARGUMENT PARSING AND CONFIG LOADING
# ---------------------------------------------------------------------------

PROG=${0}
CD_PROFILE=${1}

( [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ] ) && usage && exit 1

[ "$(whoami)" != "root" ] && die "Zaloguj sie na roota"

[ -z "$LIVECONF" ] && echo "CHROOT: konfigi na /etc/liveusb" && export LIVECONF=/etc/liveusb

[ -z "$1" ] && die "Please specify a profile, e.g.: v g e"
[ ! -d "${LIVECONF}/profiles/$CD_PROFILE" ] && die "Cannot find profile directory: ${LIVECONF}/profiles/$CD_PROFILE"

[ ! -e "${LIVECONF}/profiles/global/settings" ] && die "Cannot find global settings: ${LIVECONF}/profiles/global/settings"
[ ! -e "${LIVECONF}/profiles/${CD_PROFILE}/settings" ] && die "Cannot find profile settings for: ${CD_PROFILE}"

source "${LIVECONF}/profiles/global/settings"   || die "Failed to source global settings"
source "${LIVECONF}/profiles/${CD_PROFILE}/settings" || die "Failed to source profile settings"

# Validate required variables from settings files
for _var in DIST; do
    [ -z "${!_var}" ] && die "Required variable $_var not set in global settings"
done
# CCACHEDIR defaults to /var/cache/ccache (set after DIST-derived paths below)
# and is bind-mounted into the chroot by mount_all; blank it in settings to skip
for _var in RAMDISK; do
    [ -z "${!_var}" ] && die "Required variable $_var not set in profile ${CD_PROFILE}/settings"
done
# DEVCHROOT is optional (not needed for ramdisk profiles)
[ "$RAMDISK" = "0" ] && [ -z "$DEVCHROOT" ] && die "DEVCHROOT must be set in profile settings when RAMDISK=0"

CDLOC=$DIST/iso
[ ! -e "$CDLOC" ] && mkdir -pv "$CDLOC"

PROFILE=${CDLOC}/${CD_PROFILE}
PROFILETMP=${PROFILE}/tmp
[ ! -e "$PROFILETMP" ] && mkdir -pv "$PROFILETMP/kernel"
CHROOT=${PROFILE}/chroot
[ ! -e "$CHROOT" ] && mkdir -pv "$CHROOT"
ISO=${PROFILE}/iso
[ ! -e "$ISO" ] && mkdir -pv "$ISO"
CLOOP_FILE=${ISO}/livecd.squashfs
CD_DISTDIR=$DIST/distfiles
CD_PORTDIR=$DIST/.portage
[ ! -e "$CD_PORTDIR" ] && mkdir -pv "$CD_PORTDIR"
CD_LAYMDIR=$DIST/.repos
[ ! -e "$CD_LAYMDIR" ] && mkdir -pv "$CD_LAYMDIR"
# CCACHEDIR: persistent compiler cache shared host<->chroot, bind-mounted in
# mount_all alongside distfiles/.portage/.repos so nvcc/host objects cached on
# the host survive into chroot builds and vice versa. Defaults to the host's
# portage-owned cache (/var/cache/ccache). Override in global/settings, or set
# CCACHEDIR= (empty) there to disable the mount.
CCACHEDIR="${CCACHEDIR-/var/cache/ccache}"

HOST=0

# ---------------------------------------------------------------------------
# ARM PARAMETERS
# ---------------------------------------------------------------------------
KERNEL_ARM=raspberrypi-kernel_1.20161020-1
CROSS_COMPILE=armv7a-hardfloat-linux-gnueabi-

# ---------------------------------------------------------------------------
# CHROOT MOUNT / UMOUNT
# ---------------------------------------------------------------------------

mount_all() {
    mountpoint -q /var/tmp/portage || die "/var/tmp/portage not mounted on host"
    [ ! -e "$CHROOT/home" ] && [ -n "$DEVCHROOT" ] && mount "$DEVCHROOT" "$CHROOT"
    [ ! -e "$CHROOT$DIST/distfiles" ] && mkdir -pv "$CHROOT$DIST/distfiles"
    [ ! -e "$CHROOT$DIST/portage" ] && mkdir -pv "$CHROOT$DIST/portage"
    [ ! -e "$DIST/portage/$CD_PROFILE" ] && mkdir -pv "$DIST/portage/$CD_PROFILE"
    [ ! -e "$CHROOT/tmp/livecd" ] && mkdir -pv "$CHROOT/tmp/livecd"
    local x

    if [ "$RAMDISK" = "0" ]; then
        mount -o bind "$DIST/portage/$CD_PROFILE" "$CHROOT$DIST/portage" || chroot_die
        for x in $DIST/distfiles; do
            [ ! -e "${x}" ] && mkdir -pv "${x}"
            [ ! -e "${CHROOT}${x}" ] && mkdir -pv "${CHROOT}${x}"
            mount -o bind "${x}" "${CHROOT}${x}" || chroot_die
        done
    fi

    for x in $DIST/.portage $DIST/.src64bit $DIST/.repos /home/tmp/.packages; do
        [ ! -e "${x}" ] && mkdir -pv "${x}"
        [ ! -e "${CHROOT}${x}" ] && mkdir -pv "${CHROOT}${x}"
        mount -o bind "${x}" "${CHROOT}${x}" || chroot_die
    done

    # Shared host<->chroot compiler cache (default /var/cache/ccache; blank to skip)
    if [ -n "$CCACHEDIR" ]; then
        [ ! -e "${CCACHEDIR}" ] && mkdir -pv "${CCACHEDIR}"
        [ ! -e "${CHROOT}${CCACHEDIR}" ] && mkdir -pv "${CHROOT}${CCACHEDIR}"
        mount -o bind "${CCACHEDIR}" "${CHROOT}${CCACHEDIR}" || chroot_die
    fi

    # BINHOST_MOUNT=1 in profile settings enables sharing host binary package
    # caches with the chroot. Only for profiles matching host arch/USE (e.g. g, a).
    # Do NOT set for cross-compilation profiles (arm etc.).
    if [ "${BINHOST_MOUNT:-0}" = "1" ]; then
        for x in /var/cache/binhost/gentoobinhost /var/cache/binpkgs; do
            [ ! -e "${x}" ] && mkdir -pv "${x}"
            [ ! -e "${CHROOT}${x}" ] && mkdir -pv "${CHROOT}${x}"
            mount -o bind "${x}" "${CHROOT}${x}" || chroot_die
        done
    fi

    for x in /proc; do
        [ ! -e "${CHROOT}${x}" ] && mkdir -pv "${CHROOT}${x}"
        mount --types proc "${x}" "${CHROOT}${x}" || chroot_die
    done

    for x in /sys /dev; do
        [ ! -e "${CHROOT}${x}" ] && mkdir -pv "${CHROOT}${x}"
        mount --rbind "${x}" "${CHROOT}${x}" || chroot_die
        mount --make-rslave "${CHROOT}${x}" || chroot_die
    done

    mount -o bind "$PROFILETMP" "$CHROOT/tmp/livecd" || chroot_die
    chmod 1777 "$CHROOT/dev/shm"
}

umount_all() {
    umount "$CHROOT$DIST/portage" "$CHROOT/tmp/livecd" 2>/dev/null || true
    local x
    for x in /dev /sys /proc; do
        umount -R "${CHROOT}${x}" 2>/dev/null || true
    done
    for x in $DIST/.packages $DIST/.repos $DIST/.src64bit \
              $DIST/distfiles $DIST/.portage /home/tmp/.packages; do
        umount "${CHROOT}${x}" 2>/dev/null || true
    done
    [ -n "$CCACHEDIR" ] && umount "${CHROOT}${CCACHEDIR}" 2>/dev/null || true
    if [ "${BINHOST_MOUNT:-0}" = "1" ]; then
        umount "${CHROOT}/var/cache/binhost/gentoobinhost" 2>/dev/null || true
        umount "${CHROOT}/var/cache/binpkgs" 2>/dev/null || true
    fi
}

chroot_die() {
    umount_all
    [ -n "$1" ] && echo "chroot_generate: error: $1" || echo "chroot_generate: aborting."
    exit 1
}

trap "chroot_die" SIGINT SIGQUIT

# ---------------------------------------------------------------------------
# CORE HELPER: run a heredoc script inside chroot (or directly on host)
# ---------------------------------------------------------------------------
# Usage:
#   chroot_script <script_name> << 'EOF'
#   ...script body...
#   EOF
#
# The heredoc is read from stdin and written to $PROFILETMP/<script_name>,
# made executable, then run either in chroot or directly (HOST=1).

chroot_script() {
    local name="$1"
    local dest="$PROFILETMP/$name"
    cat > "$dest"
    chmod +x "$dest"
    if [ "$HOST" = "1" ]; then
        "$dest"
    else
        mount_all
        chroot "$CHROOT" "/tmp/livecd/$name"
        umount_all
    fi
}

# ---------------------------------------------------------------------------
# INSTALL STAGES
# ---------------------------------------------------------------------------

0etap() {
    # Deploy make.conf from profile directory into chroot, then configure
    # portage directory layout and helper scripts (vie, vix, viu, etc.)
    local profile_makeconf="${LIVECONF}/profiles/${CD_PROFILE}/make.conf"
    [ ! -e "$profile_makeconf" ] && die "Missing profile make.conf: $profile_makeconf"

    chroot_script 0etap << EOF
cd / && tar Jxf config.txz
for i in keywords use mask env; do
    [ -f /etc/portage/package.\$i ] && mv /etc/portage/package.\$i /etc/portage/package.\$i.backup
    [ ! -e /etc/portage/package.\$i ] && mkdir /etc/portage/package.\$i
    [ -f /etc/portage/package.\$i.backup ] && mv /etc/portage/package.\$i.backup /etc/portage/package.\$i/systemowe.\$i
    [ ! -e /etc/portage/package.\$i/moje.\$i ] && touch /etc/portage/package.\$i/moje.\$i
    [ ! -e /etc/portage/package.\$i/systemowe.\$i ] && touch /etc/portage/package.\$i/systemowe.\$i
done
[ ! -e /etc/portage/env ]     && mkdir /etc/portage/env
[ ! -e /etc/portage/profile ] && mkdir /etc/portage/profile
[ ! -e /etc/portage/profile/package.provided ] && touch /etc/portage/profile/package.provided
[ ! -e /usr/local/portage ] && mkdir -p /usr/local/portage/metadata/
echo "masters = gentoo" > /usr/local/portage/metadata/layout.conf

# Helper scripts: vie/vix/viu/vis/vic etc.
echo "vim /etc/portage/package.env/moje.env /etc/portage/package.env/systemowe.env"         > /usr/local/bin/vie
echo "echo \"\\\$1\" >> /etc/portage/package.keywords/moje.keywords"                         > /usr/local/bin/vex
echo "vim /etc/portage/package.keywords/moje.keywords /etc/portage/package.keywords/systemowe.keywords" > /usr/local/bin/vix
echo "echo \"\\\$1\" >> /etc/portage/package.use/moje.use"                                   > /usr/local/bin/veu
echo "vim /etc/portage/package.use/moje.use /etc/portage/package.use/systemowe.use"          > /usr/local/bin/viu
echo "echo \"\\\$1\" >> /etc/portage/package.mask/moje.mask"                                 > /usr/local/bin/ves
echo "vim /etc/portage/package.mask/moje.mask /etc/portage/package.mask/systemowe.mask"      > /usr/local/bin/vis
echo "echo \"\\\$1\" >> /etc/portage/profile/package.provided"                               > /usr/local/bin/vep
echo "vim /etc/portage/profile/package.provided"                                              > /usr/local/bin/vip
echo "echo \"\\\$1\" >> /etc/portage/make.conf"                                               > /usr/local/bin/vec
echo "vim /etc/portage/make.conf"                                                             > /usr/local/bin/vic
chmod 755 /usr/local/bin/v*
EOF

    # Deploy make.conf from profile (outside the chroot_script so it's clean)
    cp "$profile_makeconf" "${CHROOT}/etc/portage/make.conf" \
        || die "Failed to deploy make.conf from $profile_makeconf"

    if [ "$RAMDISK" = "0" ]; then
        # On persistent chroot: symlink portage tree and src to bind-mounted locations
        chroot_script 0etap-links << 'EOF'
echo "nie na LIVEDVD, gdyz ramdisk jest maly i ulotny"
[ -e /usr/portage ]  && rm -rf /usr/portage
[ ! -e /usr/portage ] && cd /usr && ln -sfn ../var/tmp/.portage portage
[ -d /usr/src ]      && rm -rf /usr/src
[ ! -e /usr/src ]    && cd /usr && ln -sfn ../var/tmp/.src64bit src
[ -e /var/db/repos ] && rm -rf /var/db/repos
[ ! -e /var/db/repos ] && cd /var/db && ln -sfn ../../var/tmp/.repos repos
EOF
    else
        chroot_script 0etap-sync << 'EOF'
emerge-webrsync
[ -d /usr/portage/distfiles ] && rmdir /usr/portage/distfiles
[ ! -d /var/tmp/distfiles ] && mkdir /var/tmp/distfiles
ln -sfn /var/tmp/distfiles /usr/portage/distfiles
EOF
    fi
}

1etap() {
    chroot_script 1etap << 'EOF'
# Set locale, profile, timezone — takes ~30 min for base compilation
echo en_US.UTF-8 UTF-8 > /etc/locale.gen
echo pl_PL.UTF-8 UTF-8 >> /etc/locale.gen
locale-gen
eselect profile set 28  # plasma systemd merged-usr 17.1
env-update
. /etc/profile
ln -sfn /usr/share/zoneinfo/Europe/Warsaw /etc/localtime
ln -sf /proc/self/mounts /etc/mtab

e g u vim
e g u eix
e g u gentoolkit genkernel portage euses

vex sys-kernel/gentoo-sources

e g u genlop net-misc/dhcpcd grub
e g u gpm app-misc/mc ntpsec
e g u app-eselect/eselect-repository
sed -i 's/^\\/dev\\//\\#\\/dev\\//g' /etc/fstab
# auto-select highest kernel number
eselect kernel set $(eselect kernel list | grep linux | wc -l)
sed -i 's/^OLDCONFIG="yes"/OLDCONFIG="no"/' /etc/genkernel.conf
EOF
}

