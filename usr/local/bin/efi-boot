#!/bin/bash
# efi-boot — Gentoo UEFI boot method installer
#
# Requires keys generated by efi-keys in WORKDIR/keys/.
# Run AFTER enrolling keys to UEFI (via BIOS or efi-keys --enroll).
#
# ---------------------------------------------------------------------------
# Security ranking — most to least secure
# Column "Key wipe" = what happens when Secure Boot keys are cleared in BIOS
# ---------------------------------------------------------------------------
#
#   [1] stub-signed / stub  +  own PK/KEK/db
#         Chain:     UEFI firmware → own db → signed kernel  (no bootloader)
#         Key wipe:  nothing boots — full lockout, maximum isolation
#         Surface:   firmware only; no bootloader code executes before kernel
#
#   [2] grub  +  own PK/KEK/db
#         Chain:     UEFI firmware → own db → signed GRUB → kernel
#         Key wipe:  nothing boots — same lockout as [1]
#         Surface:   GRUB code executes before kernel (slightly larger than [1])
#
#   [3] shim  +  MOK  (MS PK/KEK retained, no own PK)
#         Chain:     UEFI → MS PK → MS db → shim (MS-signed) → MOK → GRUB → kernel
#         Key wipe (MOK only):    Gentoo blocked, Windows unaffected
#         Key wipe (MS db reset): shim fails — everything including Windows fails
#         Dual-boot safe: does not touch PK/KEK; MOK managed from OS via mokutil
#         Risk: shim is a large trusted binary; MOK enrolled from OS, not firmware
#
#   [4] stub-signed / grub  +  db append only  (MS PK/KEK retained, no own PK)
#         Chain:     UEFI → MS PK → MS KEK → db (MS + own appended) → kernel/GRUB
#         Key wipe:  own db entry removed → kernel not MS-signed → does not boot
#         Weakest:   fully dependent on MS infrastructure
#         When to use: BIOS does not support Setup Mode (e.g. ThinkPad Deployed Mode)
#           BIOS → Security → Secure Boot → Key Management → db → Append → db.cer
#
# ---------------------------------------------------------------------------
# Methods (listed in security order):
#   stub-signed  EFI Stub: sign-only, kernel with built-in initramfs  [rank 1, confirmed working]
#   stub-luks    EFI Stub: sign-only + LUKS2 cmdline via efibootmgr   [rank 1, encrypted root]
#   stub         EFI Stub: kernel + initrd + cmdline via objcopy       [rank 1]
#   grub         GRUB standalone signed with db key, no shim          [rank 2]
#   shim         GRUB signed with MOK, shim as chain validator         [rank 3]
#   shell        EFI Shell entry (diagnostic, runs unsigned)
#   all          All of the above
#
# Usage:
#   sudo efi-boot [options]
#
# Options:
#   --disk     /dev/nvme0n1       target disk for efibootmgr (default: /dev/nvme0n1)
#   --part     1                  ESP partition number (default: 1)
#   --method   stub-signed        boot method (default: all)
#   --esp      /boot/efi          ESP mount point (default: /boot/efi)
#   --kernel   /boot/kernel-...   kernel path (auto-detected if omitted)
#   --initrd   /boot/initramfs-.. initrd path (auto-detected, optional for stub-signed)
#   --cmdline  "ro quiet splash"  kernel command line appended to CONFIG_CMDLINE
#   --workdir  ~/secureboot       must match path used in efi-keys
#   --luks-uuid UUID              LUKS2 UUID for stub-luks method (auto-detected if omitted)

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DISK="/dev/nvme0n1"
PARTITION="1"
METHOD="all"
ESP="/boot/efi"
WORKDIR="$HOME/secureboot"
KERNEL=""
INITRD=""
CMDLINE_EXTRA="ro quiet splash"
LUKS_UUID=""

GRUB_MODULES_FULL="part_gpt part_msdos ext2 fat configfile normal linux multiboot \
efi_gop efi_uga all_video gfxterm font efi_signature verifiers lockdown"
GRUB_MODULES_SHIM="part_gpt part_msdos ext2 fat configfile normal linux \
efi_gop efi_uga all_video gfxterm font"

# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------
usage() { cat << 'EOF'
Usage: sudo efi-boot [options]

Options:
  --disk     /dev/nvme0n1       target disk for efibootmgr (default: /dev/nvme0n1)
  --part     1                  ESP partition number (default: 1)
  --method   stub-signed        boot method (default: all)
  --esp      /boot/efi          ESP mount point (default: /boot/efi)
  --kernel   /boot/kernel-...   kernel path (auto-detected if omitted)
  --initrd   /boot/initramfs-.. initrd path (auto-detected, optional for stub-signed)
  --cmdline  "ro quiet splash"  kernel cmdline appended to CONFIG_CMDLINE
  --workdir  ~/secureboot       must match path used in efi-keys
  --luks-uuid UUID              LUKS2 UUID for stub-luks (auto-detected if omitted)
  -h, --help                    show this help

Methods (security rank, best first):
  stub-signed  sign kernel only, cmdline via efibootmgr NVRAM      [rank 1, recommended]
  stub-luks    stub-signed + LUKS2 rd.luks.uuid in cmdline         [rank 1, encrypted root]
  stub         kernel + initrd + cmdline embedded via objcopy       [rank 1]
  grub         GRUB standalone signed with db key, no shim         [rank 2]
  shim         GRUB signed with MOK, shim as chain validator        [rank 3]
  shell        EFI Shell entry (diagnostic, unsigned)
  all          all of the above

Examples:
  sudo efi-boot --method stub-signed
  sudo efi-boot --method stub-luks --luks-uuid 1234abcd-...
  sudo efi-boot --method stub-luks                          # auto-detect LUKS UUID
  sudo efi-boot --method grub --disk /dev/sda --part 1
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --disk)      DISK="$2";         shift 2 ;;
        --part)      PARTITION="$2";    shift 2 ;;
        --method)    METHOD="$2";       shift 2 ;;
        --esp)       ESP="$2";          shift 2 ;;
        --kernel)    KERNEL="$2";       shift 2 ;;
        --initrd)    INITRD="$2";       shift 2 ;;
        --cmdline)   CMDLINE_EXTRA="$2"; shift 2 ;;
        --workdir)   WORKDIR="$2";      shift 2 ;;
        --luks-uuid) LUKS_UUID="$2";   shift 2 ;;
        -h|--help)   usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
die()     { echo "❌  $*" >&2; exit 1; }
info()    { echo ">>>  $*"; }
ok()      { echo "✅  $*"; }
warn()    { echo "⚠️   $*"; }
need_cmd(){ command -v "$1" &>/dev/null || die "Missing tool: $1"; }

[[ $EUID -eq 0 ]] || die "Root required: sudo $0"

# ---------------------------------------------------------------------------
# Dependency check per method
# ---------------------------------------------------------------------------
need_cmd sbsign
need_cmd sbverify
need_cmd efibootmgr

case "$METHOD" in
    all|grub|shim) need_cmd grub-mkstandalone ;;
esac
case "$METHOD" in
    all|stub) need_cmd objcopy ;;
esac
case "$METHOD" in
    all|shim)
        need_cmd mokutil
        [[ -f /usr/share/shim/BOOTX64.EFI ]] \
            || die "Brak /usr/share/shim/BOOTX64.EFI — zainstaluj pakiet shim-signed"
        [[ -f /usr/share/shim/mmx64.efi ]] \
            || die "Brak /usr/share/shim/mmx64.efi"
        ;;
esac

# ---------------------------------------------------------------------------
# Key directory check
# ---------------------------------------------------------------------------
KEYDIR="$WORKDIR/keys"
[[ -f "$KEYDIR/db.key" && -f "$KEYDIR/db.crt" ]] \
    || die "No keys found in $KEYDIR — run first: sudo efi-keys"
[[ -f "$KEYDIR/MOK.key" && -f "$KEYDIR/MOK.crt" ]] \
    || die "No MOK found in $KEYDIR — re-run efi-keys"

# ---------------------------------------------------------------------------
# Auto-detect kernel
# ---------------------------------------------------------------------------
if [[ -z "$KERNEL" ]]; then
    KERNEL=$(ls -t /boot/kernel-* /boot/vmlinuz-* 2>/dev/null | head -1 || true)
    [[ -n "$KERNEL" ]] || die "No kernel found in /boot — use --kernel"
    warn "Auto-detected kernel: $KERNEL"
fi
[[ -f "$KERNEL" ]] || die "Kernel does not exist: $KERNEL"

# ---------------------------------------------------------------------------
# Auto-detect initrd
# ---------------------------------------------------------------------------
if [[ -z "$INITRD" ]]; then
    INITRD=$(ls -t /boot/initramfs-* /boot/initrd-* 2>/dev/null | head -1 || true)
    if [[ -n "$INITRD" ]]; then
        warn "Auto-detected initrd: $INITRD"
    else
        warn "No initrd in /boot — stub methods use kernel with built-in initramfs"
    fi
fi

# ---------------------------------------------------------------------------
# Build cmdline with root UUID
# ---------------------------------------------------------------------------
ROOT_PART=$(findmnt -n -o SOURCE / 2>/dev/null || true)
ROOT_UUID=""
if [[ -n "$ROOT_PART" ]]; then
    ROOT_UUID=$(blkid -o value -s UUID "$ROOT_PART" 2>/dev/null || true)
fi

if [[ -n "$ROOT_UUID" ]]; then
    CMDLINE="root=UUID=$ROOT_UUID $CMDLINE_EXTRA"
else
    warn "Root UUID not detected — falling back to ${DISK}p3, edit --cmdline"
    CMDLINE="root=${DISK}p3 $CMDLINE_EXTRA"
fi
info "cmdline: $CMDLINE"

# ---------------------------------------------------------------------------
# ESP check
# ---------------------------------------------------------------------------
mountpoint -q "$ESP" || die "ESP not mounted at $ESP"

# ---------------------------------------------------------------------------
# Directory structure on ESP
# ---------------------------------------------------------------------------
EFIDIR_GRUB="$ESP/EFI/Gentoo"
EFIDIR_SHIM="$ESP/EFI/GentooShim"
EFIDIR_STUB="$ESP/EFI/GentooEFISTUB"

# FAT32 is case-insensitive — if a case variant of the directory already
# exists, reuse it to avoid mixed-case duplicates on the ESP.
# $ESP/EFI may not exist yet (fresh ESP) — find on a missing path returns
# nonzero and with pipefail would kill the script, hence the guard and || true.
if [[ -d "$ESP/EFI" ]]; then
    for _target in Gentoo GentooShim GentooEFISTUB; do
        _dir="$ESP/EFI/$_target"
        [[ -d "$_dir" ]] && continue
        _existing=$(find "$ESP/EFI" -maxdepth 1 -iname "$_target" -type d 2>/dev/null | head -1) || true
        if [[ -n "$_existing" ]]; then
            case "$_target" in
                Gentoo)        EFIDIR_GRUB="$_existing" ;;
                GentooShim)    EFIDIR_SHIM="$_existing" ;;
                GentooEFISTUB) EFIDIR_STUB="$_existing" ;;
            esac
        fi
    done
fi

mkdir -p "$EFIDIR_GRUB" "$EFIDIR_SHIM" "$EFIDIR_STUB"
mkdir -p "$WORKDIR/grub" "$WORKDIR/shim-grub" "$WORKDIR/efistub"

# ---------------------------------------------------------------------------
# Helper: remove duplicate efibootmgr entry by label
# ---------------------------------------------------------------------------
remove_efi_entry() {
    local label="$1"
    local bootnum
    bootnum=$(efibootmgr | grep "$label" | grep -oP '(?<=Boot)[0-9A-F]{4}' | head -1 || true)
    if [[ -n "$bootnum" ]]; then
        info "  Removing old entry Boot$bootnum ($label)"
        efibootmgr -b "$bootnum" -B 2>/dev/null || true
    fi
}

# ---------------------------------------------------------------------------
# Method: GRUB standalone signed with db key                          [rank 2]
# Requires own PK/KEK/db enrolled in UEFI.
# GRUB code executes before kernel — slightly larger attack surface than stub.
# grub.cfg changes require rebuild and re-sign.
# ---------------------------------------------------------------------------
setup_grub_signed() {
    info "METHOD: GRUB standalone (signed with db key)..."

    grub-mkstandalone \
        --directory=/usr/lib/grub/x86_64-efi \
        --format=x86_64-efi \
        --output="$WORKDIR/grub/grubx64.efi" \
        --modules="$GRUB_MODULES_FULL" \
        --locales="" \
        --fonts="" \
        "boot/grub/grub.cfg=/boot/grub/grub.cfg"

    sbsign \
        --key "$KEYDIR/db.key" \
        --cert "$KEYDIR/db.crt" \
        --output "$EFIDIR_GRUB/grubx64.efi" \
        "$WORKDIR/grub/grubx64.efi"

    sbverify --list "$EFIDIR_GRUB/grubx64.efi"

    remove_efi_entry "Gentoo Secure Boot (GRUB)"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "Gentoo Secure Boot (GRUB)" \
        --loader '\EFI\Gentoo\grubx64.efi'

    ok "GRUB signed → $EFIDIR_GRUB/grubx64.efi"
}

# ---------------------------------------------------------------------------
# Method: GRUB + shim (MOK-signed GRUB)                              [rank 3]
# Does NOT require own PK — uses Microsoft-signed shim as trust anchor.
# Safe for dual-boot: PK/KEK untouched, MOK managed via mokutil from OS.
# Weakness: trust chain goes through MS infrastructure and shim binary.
# After install: mokutil --import MOK.der, then confirm in MokManager on reboot.
# ---------------------------------------------------------------------------
setup_shim() {
    info "METHOD: GRUB + shim (MOK)..."

    grub-mkstandalone \
        --directory=/usr/lib/grub/x86_64-efi \
        --format=x86_64-efi \
        --output="$WORKDIR/shim-grub/grubx64.efi" \
        --modules="$GRUB_MODULES_SHIM" \
        --locales="" \
        --fonts="" \
        "boot/grub/grub.cfg=/boot/grub/grub.cfg"

    sbsign \
        --key "$KEYDIR/MOK.key" \
        --cert "$KEYDIR/MOK.crt" \
        --output "$EFIDIR_SHIM/grubx64.efi" \
        "$WORKDIR/shim-grub/grubx64.efi"

    sbverify --list "$EFIDIR_SHIM/grubx64.efi"

    cp /usr/share/shim/BOOTX64.EFI "$EFIDIR_SHIM/shimx64.efi"
    cp /usr/share/shim/mmx64.efi   "$EFIDIR_SHIM/"
    cp "$KEYDIR/MOK.der"           "$EFIDIR_SHIM/"

    remove_efi_entry "Gentoo Shim Boot"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "Gentoo Shim Boot" \
        --loader '\EFI\GentooShim\shimx64.efi'

    echo ""
    echo "  ════════════════════════════════════════════════════════"
    echo "  WYMAGANA AKCJA — rejestracja MOK:"
    echo "    mokutil --import $EFIDIR_SHIM/MOK.der"
    echo "  Przy następnym restarcie shim otworzy MokManager."
    echo "  ════════════════════════════════════════════════════════"

    ok "Shim → $EFIDIR_SHIM/shimx64.efi"
}

# ---------------------------------------------------------------------------
# Method: EFI Stub with objcopy (embedded initrd + cmdline)          [rank 1]
# Requires own PK/KEK/db enrolled in UEFI.
# Single signed EFI file contains kernel + initrd + cmdline — no bootloader.
# Caveat: objcopy VMA offsets (0x20000, 0x3000000) may conflict with existing
# PE sections on some kernels → use stub-signed if boot fails.
# ---------------------------------------------------------------------------
setup_efistub_full() {
    info "METHOD: EFI Stub with objcopy (embedded initrd + cmdline)..."

    [[ -n "$INITRD" && -f "$INITRD" ]] \
        || die "No initrd — use --initrd or --method stub-signed for kernel with built-in initramfs"

    objcopy \
        --add-section    .cmdline=<(echo -n "$CMDLINE") \
        --change-section-vma .cmdline=0x20000 \
        --add-section    .initrd="$INITRD" \
        --change-section-vma .initrd=0x3000000 \
        "$KERNEL" \
        "$WORKDIR/efistub/vmlinuz-efistub.efi"

    sbsign \
        --key "$KEYDIR/db.key" \
        --cert "$KEYDIR/db.crt" \
        --output "$EFIDIR_STUB/vmlinuz-signed.efi" \
        "$WORKDIR/efistub/vmlinuz-efistub.efi"

    sbverify --list "$EFIDIR_STUB/vmlinuz-signed.efi"

    remove_efi_entry "Gentoo EFI Stub (initrd embedded)"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "Gentoo EFI Stub (initrd embedded)" \
        --loader '\EFI\GentooEFISTUB\vmlinuz-signed.efi'

    ok "EFI Stub objcopy → $EFIDIR_STUB/vmlinuz-signed.efi"
}

# ---------------------------------------------------------------------------
# Method: EFI Stub signed only (built-in initramfs)     [rank 1, CONFIRMED]
# Requires own PK/KEK/db enrolled in UEFI.
# Kernel compiled with CONFIG_INITRAMFS_SOURCE — no external initrd needed.
# Simplest and most reliable stub variant: sign + efibootmgr only, no objcopy.
# cmdline passed via efibootmgr --unicode (stored in NVRAM, not in EFI file).
# After kernel update: re-run this method only — no grub.cfg rebuild needed.
# ---------------------------------------------------------------------------
setup_efistub_signed() {
    info "METHOD: EFI Stub signed only (kernel with built-in initramfs)..."

    # Kernel compiled with CONFIG_INITRAMFS_SOURCE pointing to pre-built initramfs.
    # No external initrd needed — cmdline passed via efibootmgr --unicode.
    sbsign \
        --key "$KEYDIR/db.key" \
        --cert "$KEYDIR/db.crt" \
        --output "$EFIDIR_STUB/vmlinuz-signed.efi" \
        "$KERNEL"

    sbverify --list "$EFIDIR_STUB/vmlinuz-signed.efi"

    remove_efi_entry "Gentoo EFI Stub"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "Gentoo EFI Stub" \
        --loader '\EFI\GentooEFISTUB\vmlinuz-signed.efi' \
        --unicode "$CMDLINE"

    ok "EFI Stub signed → $EFIDIR_STUB/vmlinuz-signed.efi"
}

# ---------------------------------------------------------------------------
# Method: EFI Stub signed only + LUKS2 cmdline                       [rank 1]
# Identical to stub-signed but cmdline includes rd.luks.uuid for LUKS2 root.
# Kernel built with CONFIG_CMDLINE (base) without OVERRIDE — efibootmgr
# --unicode appends to kernel's built-in cmdline, so rd.luks.uuid is added
# on top of CONFIG_CMDLINE without modifying the kernel binary.
# Requires genkernel built with --luks (cryptsetup in initramfs).
# ---------------------------------------------------------------------------
setup_efistub_luks() {
    info "METHOD: EFI Stub signed + LUKS2..."

    if [[ -z "$LUKS_UUID" ]]; then
        # Auto-detect from currently open LUKS devices
        local _raw
        _raw=$(dmsetup info -c --noheadings -o uuid 2>/dev/null | head -1 \
            | sed 's/^CRYPT-LUKS2-//' | sed 's/-[^-]*$//' || true)
        if [[ -z "$_raw" ]]; then
            die "Provide LUKS UUID via --luks-uuid UUID or open container: cryptsetup luksOpen /dev/... gentoo_crypt"
        fi
        # dmsetup strips dashes — reformat to xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
        LUKS_UUID=$(echo "$_raw" | sed \
            's/\([0-9a-f]\{8\}\)\([0-9a-f]\{4\}\)\([0-9a-f]\{4\}\)\([0-9a-f]\{4\}\)\([0-9a-f]\{12\}\)/\1-\2-\3-\4-\5/')
        warn "Auto-detected LUKS UUID: $LUKS_UUID"
    fi

    # Build cmdline: kernel CONFIG_CMDLINE is base, efibootmgr --unicode appends
    # rd.luks.uuid tells dracut/genkernel initramfs which device to unlock
    local LUKS_CMDLINE="crypt_root=UUID=$LUKS_UUID root=/dev/mapper/gentoo_crypt $CMDLINE_EXTRA"
    info "LUKS cmdline (appended to CONFIG_CMDLINE): $LUKS_CMDLINE"

    sbsign \
        --key "$KEYDIR/db.key" \
        --cert "$KEYDIR/db.crt" \
        --output "$EFIDIR_STUB/vmlinuz-signed-luks.efi" \
        "$KERNEL"

    sbverify --list "$EFIDIR_STUB/vmlinuz-signed-luks.efi"

    remove_efi_entry "Gentoo EFI Stub LUKS"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "Gentoo EFI Stub LUKS" \
        --loader '\EFI\GentooEFISTUB\vmlinuz-signed-luks.efi' \
        --unicode "$LUKS_CMDLINE"

    ok "EFI Stub LUKS → $EFIDIR_STUB/vmlinuz-signed-luks.efi"
    echo ""
    echo "  LUKS UUID w NVRAM: $LUKS_UUID"
    echo "  Pełny cmdline:     $(efibootmgr -v | grep 'Gentoo EFI Stub LUKS' | sed -E 's/.*\.efi//' | xxd -r -p|| true)"
    echo ""
    echo "  Requirements:"
    echo "  - genkernel built with --luks: genkernel --luks initramfs"
    echo "  - /etc/crypttab: gentoo_crypt UUID=$LUKS_UUID none luks"
}
setup_efi_shell() {
    info "METHOD: EFI Shell..."

    local SHELL_DIR="$ESP/EFI/Shell"
    mkdir -p "$SHELL_DIR"

    if [[ ! -f "$SHELL_DIR/shellx64.efi" ]]; then
        warn "Brak $SHELL_DIR/shellx64.efi"
        echo "  Download:"
        echo "  wget -O $SHELL_DIR/shellx64.efi \\"
        echo "    https://github.com/tianocore/edk2/raw/edk2-stable202302/ShellBinPkg/UefiShell/X64/Shell.efi"
        return
    fi

    remove_efi_entry "EFI Shell"
    efibootmgr --create \
        --disk "$DISK" --part "$PARTITION" \
        --label "EFI Shell" \
        --loader '\EFI\Shell\shellx64.efi'

    ok "EFI Shell → $SHELL_DIR/shellx64.efi"
}

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
print_summary() {
    echo ""
    echo "════════════════════════════════════════════════════════════"
    echo "  UEFI boot entries:"
    efibootmgr -v | grep -E "Boot[0-9A-F]{4}" || true
    echo ""
    echo "  ESP/EFI structure:"
    find "$ESP/EFI" -maxdepth 2 -type f | sort | sed "s|$ESP||"
    echo "════════════════════════════════════════════════════════════"
    echo ""
    echo "After kernel update re-run:"
    echo "  sudo efi-boot --method stub-signed  (lub odpowiednią metodę)"
    echo ""
    echo "If Windows overwrites EFI/Boot/bootx64.efi:"
    echo "  cp $ESP/EFI/Microsoft/Boot/bootmgfw.efi $ESP/EFI/Boot/bootx64.efi"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  efi-boot — Gentoo UEFI boot installer"
echo "  Disk: $DISK  ESP partition: $PARTITION  Method: $METHOD"
echo "  Kernel: $KERNEL"
echo "  Initrd: ${INITRD:-<brak>}"
echo "  Cmdline: $CMDLINE"
echo "════════════════════════════════════════════════════════════"
echo ""

case "$METHOD" in
    all)
        setup_grub_signed
        setup_shim
        if [[ -n "$INITRD" && -f "$INITRD" ]]; then
            setup_efistub_full
        else
            warn "Skipping stub (objcopy) — no initrd"
        fi
        setup_efistub_signed
        setup_efi_shell
        ;;
    grub)        setup_grub_signed ;;
    shim)        setup_shim ;;
    stub)        setup_efistub_full ;;
    stub-signed) setup_efistub_signed ;;
    stub-luks)   setup_efistub_luks ;;
    shell)       setup_efi_shell ;;
    *) die "Unknown method: $METHOD. Available: all grub shim stub stub-signed stub-luks shell"
esac

print_summary
