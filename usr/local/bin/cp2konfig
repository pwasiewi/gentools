#!/bin/bash
set -euo pipefail

ISO_BASE="/var/tmp/iso"

usage() {
  echo "Usage: $0 <path> [<profile>] [-f|--from-iso]" >&2
  echo "       $0 <path> [-c <profile>] [-f|--from-iso]" >&2
  echo "Available profiles: config $(ls /etc/liveusb/profiles/ 2>/dev/null | tr '\n' ' ')" >&2
  exit 1
}

[ $# -eq 0 ] && usage

SRC_ARG="$1"; shift
CHROOT="config"
MODE="to-iso"

# Positional shorthand: a second arg that isn't an option is the profile,
# equivalent to `-c <profile>`. Explicit `-c` later still overrides it.
if [ $# -gt 0 ] && [[ "$1" != -* ]]; then
  CHROOT="$1"
  shift
fi

while [ $# -gt 0 ]; do
  case "$1" in
    -c|--chroot)
      CHROOT="$2"
      shift 2
      ;;
    -f|--from-iso)
      MODE="from-iso"; shift
      ;;
    *) break ;;
  esac
done

if [ "$CHROOT" != "config" ]; then
  [ -d "/etc/liveusb/profiles/$CHROOT" ] || {
    echo "Error: profile '$CHROOT' does not exist in /etc/liveusb/profiles/" >&2
    echo "Available profiles: config $(ls /etc/liveusb/profiles/ 2>/dev/null | tr '\n' ' ')" >&2
    exit 2
  }
fi

if [ "$CHROOT" = "config" ]; then
  WHERE="/config"
else
  WHERE="/$CHROOT/chroot"
fi

# Canonical root of the ISO tree; ISO_BASE itself may be a symlink chain
# (e.g. /var/tmp/iso -> /home/tmp/iso -> /mnt/dc/iso), so all containment
# checks compare against the resolved path.
ISO_ROOT="$(realpath -e "$ISO_BASE")" || {
  echo "Error: ISO base not found: $ISO_BASE" >&2
  exit 3
}

confirm_replace_dir() {
  local target="$1"
  if [ -d "$target" ]; then
    printf "Replace existing directory '%s'? [y/N] " "$target" >&2
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted." >&2; exit 0; }
  fi
}

# Abort unless the fully resolved path lies inside the ISO tree. Prevents
# rm/cp/ln from acting on the live filesystem when an absolute symlink
# copied into the ISO tree redirects a destination component outside it.
assert_inside_iso() {
  local resolved="$1" original="$2"
  case "$resolved" in
    "$ISO_ROOT"/*) ;;
    *)
      echo "Error: path escapes ISO tree: $original -> $resolved" >&2
      exit 4
      ;;
  esac
}

# Interactive resolution of conflicts at a symlink location in the ISO tree.
# Prompts go to stderr because the walk runs inside command substitution.
# Answers: y = replace with the live-system link, k = keep ISO state as-is
# (only offered for a diverging symlink), anything else = abort so the
# conflict can be resolved manually.
resolve_link_conflict() {
  local iso_path="$1" live_target="$2" answer
  if [ -L "$iso_path" ]; then
    local iso_target
    iso_target="$(readlink "$iso_path")"
    [ "$iso_target" = "$live_target" ] && return 0
    {
      echo "Conflict: symlink target differs in ISO tree:"
      echo "  ISO:  $iso_path -> $iso_target"
      echo "  live: -> $live_target"
      printf "Replace with live target / keep ISO version / abort? [y/k/N] "
    } >&2
    read -r answer
    case "$answer" in
      [Yy]) ln -sfn "$live_target" "$iso_path" ;;
      [Kk]) return 0 ;;
      *) echo "Aborted; resolve manually: $iso_path" >&2; exit 6 ;;
    esac
  elif [ -e "$iso_path" ]; then
    {
      echo "Conflict: ISO path exists but is not a symlink (stale copy made"
      echo "through the symlink by an older version?):"
      ls -ld "$iso_path" >&2 || true
      printf "Replace it with symlink -> %s / abort? [y/N] " "$live_target"
    } >&2
    read -r answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      rm -rf "$iso_path"
      ln -s "$live_target" "$iso_path"
    else
      echo "Aborted; resolve manually: $iso_path" >&2
      exit 6
    fi
  else
    mkdir -p "$(dirname "$iso_path")"
    ln -s "$live_target" "$iso_path"
  fi
}

# namei-style walk of a live-system path: resolves it to the physical
# location while recreating every traversed symlink (verbatim, including
# relative targets and link->link chains) at the corresponding physical
# location inside the ISO tree. This makes the chain resolve identically
# in the booted live system, where absolute link targets are interpreted
# against its own root. Prints the fully resolved physical path.
canonicalize_and_replicate() {
  local path depth=0 resolved=""
  # realpath -sm: absolute + lexically normalized (., ..), symlinks untouched
  path="$(realpath -sm "$1")"
  while [ "$path" != "$resolved" ]; do
    local rest="${path#"$resolved"}"; rest="${rest#/}"
    local comp="${rest%%/*}"
    local cand="$resolved/$comp"
    if [ -L "$cand" ]; then
      (( ++depth > 40 )) && { echo "Error: too many levels of symlinks: $1" >&2; exit 5; }
      local target iso_link iso_link_real remainder
      target="$(readlink "$cand")"
      iso_link="${ISO_BASE}${WHERE}${cand}"
      iso_link_real="$(realpath -sm "$(realpath -m "$(dirname "$iso_link")")/$(basename "$iso_link")")"
      assert_inside_iso "$iso_link_real" "$iso_link"
      resolve_link_conflict "$iso_link_real" "$target"
      # splice the link target into the remaining path and restart the walk
      remainder="${rest#"$comp"}"
      if [[ "$target" = /* ]]; then
        path="$(realpath -sm "${target}${remainder}")"
      else
        path="$(realpath -sm "${resolved}/${target}${remainder}")"
      fi
      resolved=""
    else
      resolved="$cand"
    fi
  done
  printf '%s\n' "$resolved"
}

if [ "$MODE" = "from-iso" ]; then
  # Canonicalize the live-system target so the ISO-side lookup uses the same
  # physical path that to-iso mode writes to. -m tolerates a not-yet-existing
  # final component while still resolving existing symlinks.
  SRC="$(realpath -m "$SRC_ARG")"
  ISO_SRC="${ISO_BASE}${WHERE}${SRC}"
  [ -e "$ISO_SRC" ] || { echo "Error: ISO source not found: $ISO_SRC" >&2; exit 3; }
  REAL_ISO_SRC="$(realpath -e "$ISO_SRC")"
  assert_inside_iso "$REAL_ISO_SRC" "$ISO_SRC"
  if [ "$REAL_ISO_SRC" = "$SRC" ]; then
    echo "Error: ISO source resolves to live target: $SRC" >&2
    exit 4
  fi
  DEST_DIR="$(dirname "$SRC")"
  if [ -d "$ISO_SRC" ]; then
    confirm_replace_dir "$SRC"
  fi
  mkdir -p "$DEST_DIR"
  rm -rf "$SRC"
  cp -a "$ISO_SRC" "$DEST_DIR"
  echo "Copied $ISO_SRC → $DEST_DIR"
else
  [ -e "$SRC_ARG" ] || [ -L "$SRC_ARG" ] || {
    echo "Error: source not found: $SRC_ARG" >&2
    exit 3
  }
  # Resolve to the physical package location, replicating every symlink
  # encountered along the way (e.g. cups/model/foomatic-db-ppds ->
  # /usr/share/foomatic/db/source/PPD) so the destination chroot gets both
  # the payload at its canonical path and the links needed to reach it.
  # The walk runs in a subshell; exit code 6 marks a user-chosen abort
  # inside a conflict prompt and must not be reported as an error.
  if ! SRC="$(canonicalize_and_replicate "$SRC_ARG")"; then
    rc=$?
    [ "$rc" -eq 6 ] && exit 0
    exit "$rc"
  fi
  [ -e "$SRC" ] || { echo "Error: broken symlink chain: $SRC_ARG -> $SRC" >&2; exit 3; }
  DEST_DIR="${ISO_BASE}${WHERE}$(dirname "$SRC")"
  DEST="$DEST_DIR/$(basename "$SRC")"
  if [ -d "$SRC" ]; then
    confirm_replace_dir "$DEST"
  fi
  mkdir -p "$DEST_DIR"
  # Resolve after mkdir -p so any pre-existing symlinked components in the
  # destination path are followed and the escape check sees the real target.
  REAL_DEST="$(realpath -m "$DEST")"
  assert_inside_iso "$REAL_DEST" "$DEST"
  rm -rf "$REAL_DEST"
  cp -a "$SRC" "$DEST_DIR"
  echo "Copied $SRC → $DEST_DIR"
fi
