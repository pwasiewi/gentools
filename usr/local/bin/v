    chroot_script 4etap << 'EOF'
# X11 utilities, fonts, networking tools — takes ~14 min
vex net-analyzer/xprobe
veu "dev-libs/libnl utils"
e g u setxkbmap xdpyinfo xrandr xkill xterm alsamixergui gparted \
    media-fonts/liberation-fonts freetype pavucontrol feh lm-sensors xsensors \
