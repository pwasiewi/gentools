}

5etap() {
    chroot_script 5etap << 'EOF'
# KDE Plasma desktop — takes ~32 min
eselect repository enable kde
emaint sync --repo kde
eselect repository enable steam-overlay
emaint sync --repo steam-overlay
eix-update
e g u networkmanager
e g u plasma-meta
